<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F9F9F9">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HỆ THỐNG IMPORT DỮ LIỆU"
        android:textColor="#212121"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/btnSelectExcel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="1. Chọn file Excel từ máy"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"/>

    <TextView
        android:id="@+id/tvSelectedFileName"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Chưa chọn file nào (*.xlsx, *.xls)"
        android:textColor="#757575"
        android:textStyle="italic"
        android:textSize="13sp"/>

    <TextView
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="2. Chọn danh mục / Đợt khảo sát:"
        android:textColor="#424242"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spLoaiHo"
        android:layout_width="280dp"
        android:layout_height="48dp"
        android:layout_marginBottom="32dp"
        android:paddingStart="12dp"
        android:paddingEnd="36dp"
        android:background="@drawable/spinner_border"
        android:spinnerMode="dropdown" />

    <Button
        android:id="@+id/btnImportExcel"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:text="3. Bắt đầu Import dữ liệu"
        android:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:visibility="gone" />

</LinearLayout>